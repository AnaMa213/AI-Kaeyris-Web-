# Backend base URL (FastAPI on the LAN host).
# In local dev the backend listens on port 8000.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Mock GET /services/jdr/sessions/{id}/audio until backend BD-2 ships.
# Toggle to "false" once the backend exposes the audio playback endpoint.
NEXT_PUBLIC_MOCK_AUDIO=true

# Mock DELETE /services/jdr/pjs/{id} until backend BD-3 ships.
# Toggle to "false" once the backend exposes PJ deletion.
NEXT_PUBLIC_MOCK_PJ_DELETE=true

# Whether the client should run a ffmpeg.wasm reduce pass before upload.
# Default is "false" : the client reducer is dormant in V1 — ffmpeg.wasm 0.12+
# needs COOP/COEP headers (SharedArrayBuffer) that next.config.ts does not
# serve, so the reduce hangs silently. The backend will own audio reduction
# in BD-9 (see docs/backend-handoffs/BD-9-backend-audio-reduce.md).
# Flip to "true" only if you have configured COOP/COEP and want to test the
# legacy client-side path.
NEXT_PUBLIC_AUDIO_REDUCER_REQUIRED=false

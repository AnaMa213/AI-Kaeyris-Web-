# Backend base URL (FastAPI on the LAN host).
# In local dev the backend listens on port 8000.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Mock GET /services/jdr/sessions/{id}/audio until backend BD-2 ships.
# Toggle to "false" once the backend exposes the audio playback endpoint.
NEXT_PUBLIC_MOCK_AUDIO=true

# Mock DELETE /services/jdr/pjs/{id} until backend BD-3 ships.
# Toggle to "false" once the backend exposes PJ deletion.
NEXT_PUBLIC_MOCK_PJ_DELETE=true

# Whether the backend transcription provider requires client-side audio reduction.
# true  = cloud Whisper enforces a 25 MB cap -> client must reduce via ffmpeg.wasm
# false = local provider has no cap -> client skips reducer
NEXT_PUBLIC_AUDIO_REDUCER_REQUIRED=true
